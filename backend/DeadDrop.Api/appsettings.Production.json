{
  "Cors": {
    "AllowedOrigins": ["https://deaddrop.codystine.com", "https://www.deaddrop.codystine.com"]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning",
        "Pawthorize": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Secret": ""
  },
  "StashPup": {
    "Provider": "S3",
    "S3": {
      "BucketName": "deaddrop",
      "Region": "garage",
      "ServiceUrl": "",
      "ForcePathStyle": true,
      "AccessKeyId": "",
      "SecretAccessKey": "",
      "EnableEncryption": false
    }
  }
}
